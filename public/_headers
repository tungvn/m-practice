# Cloudflare Pages response headers.
# Security headers apply to every response; long-lived immutable caching is
# applied only to content-hashed / effectively-immutable assets.
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  X-Frame-Options: DENY
  Cross-Origin-Opener-Policy: same-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), usb=(), payment=()
  # CSP for a 100% static, client-only app. Notes on the non-obvious bits:
  #  - script-src 'unsafe-inline': Next's static export embeds inline bootstrap
  #    scripts and there is no server to mint per-request nonces. There are no
  #    third-party scripts, so this still forbids loading script from any other
  #    origin (and 'unsafe-eval' is intentionally omitted; pdf.js degrades).
  #  - 'wasm-unsafe-eval': pdf.js compiles WebAssembly image decoders.
  #  - worker-src 'self' blob': the self-hosted pdf.js worker (and its blob
  #    fallback).
  #  - style-src 'unsafe-inline': Next/next-font inject a small inline <style>.
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; media-src 'self'; connect-src 'self'; worker-src 'self' blob:; manifest-src 'self'

# Content-hashed build output — the filename changes when the bytes change, so
# it is always safe to cache forever.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Lesson media (PDFs + MP3s). Large and effectively immutable per lesson, so a
# long immutable cache makes repeat opens near-instant.
# CAVEAT: if you OVERWRITE an asset in place (same filename), returning visitors
# may keep the cached copy until eviction. Prefer adding new lessons as new
# files/folders; if you must replace one in place, change its name or purge the
# Cloudflare cache for that path.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# The manifest is the one mutable file under /assets — it changes every build.
# More specific than /assets/* above, so this rule wins. (The app also fetches
# it with `cache: "no-cache"`; this keeps the CDN/browser honest too.)
/assets/manifest.json
  Cache-Control: public, max-age=0, must-revalidate

# Version-critical and NOT content-hashed: must revalidate so bumping pdfjs
# never serves a stale worker (the documented silent-render-failure risk).
/pdf.worker.min.mjs
  Cache-Control: public, max-age=0, must-revalidate
